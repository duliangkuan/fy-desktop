{
  "name": "fy-desktop",
  "version": "2.0.0",
  "description": "EasyCC：装上就能用 Claude Code / Codex 的桌面工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis",
    "dist:full": "electron-builder --win nsis --config.extraResources=cli-bundle --config.nsis.artifactName=EasyCC-Full-Setup-${version}.exe"
  },
  "author": "风云",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.fengyun.aitools",
    "productName": "EasyCC",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor-node/node.exe",
        "to": "node/node.exe"
      },
      {
        "from": "relay-worker.js",
        "to": "relay-worker.js"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "shortcutName": "EasyCC",
      "artifactName": "EasyCC-Setup-${version}.exe"
    },
    "compression": "maximum",
    "afterPack": "./afterPack.js"
  }
}